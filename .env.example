# TASALO Miniapp - Environment Configuration
# Copiar a .env y completar valores

# Flask
FLASK_SECRET_KEY=tu_clave_secreta_aqui
FLASK_ENV=production  # development o production
PORT=5000

# Backend API URL (se inyecta en templates para fetch del cliente)
TASALO_API_URL=https://api.tasalo.app

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# --- Notas ---
# FLASK_SECRET_KEY: Generar con secrets.token_hex(32) en Python
# TASALO_API_URL: URL de taso-api sin trailing slash
# PORT: Puerto para gunicorn (default 5000)
